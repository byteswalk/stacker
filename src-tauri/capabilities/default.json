{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "live-log"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "dialog:allow-save",
    "dialog:allow-open",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
